# Rename this file to .env and fill in your credentials.

# --- LLM Provider (choose one) ---
LLM_PROVIDER=openai          # options: openai | gemini

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Google Gemini ---
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# --- General ---
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

# --- Tesseract OCR (Windows path example) ---
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
